GOOGLE_CLIENT_ID=

GOOGLE_APPLICATION_CREDENTIALS=
BQ_PROJECT_NAME=
BQ_DATASET_NAME=

OPENAI_API_KEY=

S3_BUCKET_NAME=
S3_FOLDER_NAME=

ENV=development

SLACK_USER_SIGNUP_WEBHOOK_URL=
SLACK_USAGE_STATS_WEBHOOK_URL=
SLACK_COURSE_CREATED_WEBHOOK_URL=
SLACK_ALERT_WEBHOOK_URL=

SENTRY_DSN=
SENTRY_ENVIRONMENT=

# ── Intelligence Thresholds (tunable by ops/admin) ──────────────────────────
# Fraction of cohort stuck on a task before it's flagged as systemic (default 35%)
SYSTEMIC_THRESHOLD=0.35
# Completion pace drop before velocity risk is triggered (default 50%)
VELOCITY_DROP_THRESHOLD=0.50
# Min messages on same question in one day to flag repetition signal
REPETITION_MIN_MESSAGES=3
# Min messages without submission to flag no-submission signal
NO_SUBMISSION_MIN_MESSAGES=5
# Minutes on a single question before time-on-task signal fires
TIME_ON_TASK_THRESHOLD_MINUTES=30